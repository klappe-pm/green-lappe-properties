// Devcontainer for green-property-solutions (Phase 8 E8.3 migration).
//
// Seeded from the harness base template (containers/base/devcontainer.template.jsonc).
// The mounts block is GENERATED from environments/local-dev.access.json by the
// E2.2 generator when `harness env up` runs; hand edits inside the generated
// block are bugs. It ships empty here so `env up` renders the live mount set
// from the access config. Security posture: non-root user, all capabilities
// dropped, no privilege escalation, no docker socket, workspace plus declared
// mounts only, no blanket $HOME mount.
{
  "name": "green-property-solutions-dev",
  "image": "harness-base:latest",

  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/${localWorkspaceFolderBasename},type=bind",
  "workspaceFolder": "/workspace/${localWorkspaceFolderBasename}",

  "remoteUser": "agent",
  "containerUser": "agent",

  "runArgs": [
    "--cap-drop=ALL",
    "--security-opt", "no-new-privileges"
  ],

  // BEGIN GENERATED MOUNTS (access-v1 -> E2.2 generator; do not hand-edit).
  // Shared-store mounts (claude-config here) render read-only unless the access
  // config's `why` grants rw.
  "mounts": [],
  // END GENERATED MOUNTS.

  "containerEnv": {
    "HARNESS_SESSION_DB": "/mnt/session-data/sessions.db"
  },

  // Posture verification on every start; red output means the container does
  // not match the declared access config.
  "postStartCommand": "harness env doctor",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
