{
  "name": "green-lappe-properties",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Green Property Management marketing site + portals (Astro + Tailwind + Sanity). Feature-organized.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "astro check",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:coverage": "vitest run -c vitest.config.ts --coverage",
    "test:components": "vitest run -c vitest.components.config.ts",
    "test:static": "vitest run -c vitest.static.config.ts",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "prettier --write \"src/**/*.{astro,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{astro,css,md}\""
  },
  "dependencies": {
    "@sanity/client": "^6.29.1",
    "astro": "^4.16.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/tailwind": "^5.1.4",
    "@biomejs/biome": "1.9.4",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^2.1.9",
    "cheerio": "^1.2.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
