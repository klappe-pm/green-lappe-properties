{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -x:*)",
      "Bash(git branch -D:*)",
      "Bash(git rebase:*)",
      "Bash(git filter-branch:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(find * -delete)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(pnpm add *)",
      "Bash(yarn add *)",
      "Bash(brew *)",
      "Bash(docker *)"
    ],
    "allow": [
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(node *)",
      "Bash(npx astro *)",
      "Bash(npx vitest *)",
      "Bash(npx biome *)",
      "Bash(npx playwright *)",
      "Bash(npx prettier *)",
      "Bash(npx tsc *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(mkdir *)",
      "Bash(rmdir *)",
      "Bash(chmod *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln -s *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)"
    ]
  }
}
