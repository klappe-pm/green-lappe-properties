---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import PostCard from '../../../features/blog/PostCard.astro';
import { fetchAllTags, fetchPostsByTag } from '../../../features/blog/posts';

export const getStaticPaths = (async () => {
  const tags = await fetchAllTags();
  return Promise.all(
    tags.map(async (tag) => ({ params: { tag }, props: { tag, posts: await fetchPostsByTag(tag) } })),
  );
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`} audience="neutral-acquisition" description={`Field notes tagged ${tag}.`}>
  <section class="py-16">
    <Container width="lg">
      <a href="/blog" class="text-sm text-cedar underline underline-offset-2">← All field notes</a>
      <p class="eyebrow mt-6">Tag</p>
      <h1 class="mt-3">#{tag}</h1>
      <div class="mt-6">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </Container>
  </section>
</BaseLayout>
