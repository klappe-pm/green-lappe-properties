---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PortalShell from '../../../features/portal/PortalShell.astro';
import { residentPortalNav } from '../../../lib/nav';
import { getResidentLease } from '../../../features/portal/data';
import { formatRent } from '../../../lib/format';

const lease = getResidentLease();
const due = new Date(`${lease.nextDueDate}T00:00:00`).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title="Pay rent" audience="renter-product">
  <PortalShell heading="Pay rent" nav={residentPortalNav}>
    <div class="max-w-[480px] rounded-lg border border-[color:var(--color-divider)] p-6">
      <p class="text-sm text-ink-60">Amount due</p>
      <p class="tabular font-display text-3xl font-semibold text-ink">{formatRent(lease.rent).replace('/mo', '')}</p>
      <p class="mt-1 text-sm text-ink-60">Due {due} · {lease.property}</p>
      <button
        type="button"
        disabled
        class="mt-6 inline-flex min-h-touch cursor-not-allowed items-center rounded-md bg-ink-40 px-6 py-3 font-display font-semibold text-cream"
      >
        Pay with the Rentvine widget
      </button>
      <p class="mt-3 text-sm text-ink-60">
        Payments are processed by the property-management system (Rentvine). The
        payment widget appears here once your account is connected — we don’t
        rebuild payments.
      </p>
    </div>
  </PortalShell>
</BaseLayout>
