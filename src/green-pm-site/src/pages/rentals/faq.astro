---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import FaqList from '../../features/faq/FaqList.astro';
import { fetchFaqs } from '../../features/faq/faqs';
const faqs = await fetchFaqs('renter');
---
<BaseLayout title="Renter FAQ" audience="renter-acquisition" description="Common questions from renters and residents.">
  <section class="py-16">
    <Container width="prose">
      <p class="eyebrow">For renters</p>
      <h1 class="mt-4 mb-8">Renter FAQ</h1>
      <FaqList faqs={faqs} />
    </Container>
  </section>
</BaseLayout>
