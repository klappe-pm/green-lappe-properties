---
/**
 * Renter inquiry form (renter acquisition flow step 5-6).
 *
 * NOT YET WIRED: submits to HubSpot Forms per the system architecture. Until
 * the portal/form IDs + Turnstile are configured it renders with a disabled
 * submit and a mailto fallback so no inquiry is silently dropped.
 * See docs/81-user-flows.md (Renter Acquisition Flow).
 */
import { site } from '../../config/site';

interface Props {
  /** Pre-fills the subject when inquiring about a specific home. */
  listingAddress?: string;
}
const { listingAddress } = Astro.props as Props;
const subject = listingAddress
  ? `Inquiry: ${listingAddress}`
  : 'Rental inquiry';
---
<form class="grid max-w-[640px] grid-cols-1 gap-5 sm:grid-cols-2" aria-describedby="inquiry-status">
  {listingAddress && <input type="hidden" name="listing" value={listingAddress} />}
  <div>
    <label for="name" class="block font-display text-sm font-medium text-ink-80">
      Name <span aria-hidden="true" class="text-clay">*</span>
    </label>
    <input id="name" name="name" type="text" required
      class="mt-1 min-h-touch w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base" />
  </div>
  <div>
    <label for="email" class="block font-display text-sm font-medium text-ink-80">
      Email <span aria-hidden="true" class="text-clay">*</span>
    </label>
    <input id="email" name="email" type="email" required
      class="mt-1 min-h-touch w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base" />
  </div>
  <div>
    <label for="phone" class="block font-display text-sm font-medium text-ink-80">
      Phone <span aria-hidden="true" class="text-clay">*</span>
    </label>
    <input id="phone" name="phone" type="tel" required
      class="mt-1 min-h-touch w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base" />
  </div>
  <div>
    <label for="move_in_date" class="block font-display text-sm font-medium text-ink-80">
      Target move-in <span aria-hidden="true" class="text-clay">*</span>
    </label>
    <input id="move_in_date" name="move_in_date" type="date" required
      class="mt-1 min-h-touch w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base" />
  </div>
  <div class="sm:col-span-2">
    <label for="message" class="block font-display text-sm font-medium text-ink-80">Message</label>
    <textarea id="message" name="message" rows="4"
      class="mt-1 w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base"></textarea>
  </div>

  {/* Honeypot */}
  <div class="hidden" aria-hidden="true">
    <label>Leave this empty<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
  </div>

  <div class="sm:col-span-2">
    <button type="submit" disabled
      class="inline-flex min-h-touch cursor-not-allowed items-center rounded-md bg-ink-40 px-6 py-3 font-display font-semibold text-cream">
      Send inquiry
    </button>
    <p id="inquiry-status" class="mt-3 text-sm text-ink-60">
      Online inquiries are being connected. For now, email
      <a href={`mailto:${site.email}?subject=${encodeURIComponent(subject)}`} class="text-cedar underline">{site.email}</a>
      and Megan will reply within one business day.
    </p>
  </div>
</form>
