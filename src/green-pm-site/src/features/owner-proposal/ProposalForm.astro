---
/**
 * Owner proposal request form.
 *
 * NOT YET WIRED: per the system architecture, this submits to HubSpot Forms.
 * Until the HubSpot portal/form IDs and Cloudflare Turnstile are configured,
 * the form is rendered with a disabled submit and a mailto fallback so no real
 * lead is silently dropped. See docs/81-user-flows.md (Owner Acquisition Flow).
 */
import { site } from '../../config/site';

type FieldType = 'text' | 'email' | 'tel' | 'number';
interface Field {
  id: string;
  label: string;
  type: FieldType;
  required: boolean;
  half: boolean;
}
const fields: Field[] = [
  { id: 'first_name', label: 'First name', type: 'text', required: true, half: true },
  { id: 'last_name', label: 'Last name', type: 'text', required: true, half: true },
  { id: 'email', label: 'Email', type: 'email', required: true, half: true },
  { id: 'phone', label: 'Phone', type: 'tel', required: false, half: true },
  { id: 'property_address', label: 'Property address', type: 'text', required: true, half: false },
  { id: 'number_of_doors', label: 'Number of doors', type: 'number', required: true, half: true },
  { id: 'current_pm', label: 'Current property manager', type: 'text', required: false, half: true },
];
---
<form class="max-w-form-none grid max-w-[640px] grid-cols-1 gap-5 sm:grid-cols-2" aria-describedby="proposal-status">
  {
    fields.map((f) => (
      <div class={f.half ? '' : 'sm:col-span-2'}>
        <label for={f.id} class="block font-display text-sm font-medium text-ink-80">
          {f.label}
          {f.required && <span aria-hidden="true" class="text-clay"> *</span>}
        </label>
        <input
          id={f.id}
          name={f.id}
          type={f.type}
          required={f.required}
          class="mt-1 min-h-touch w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base"
        />
      </div>
    ))
  }
  <div class="sm:col-span-2">
    <label for="message" class="block font-display text-sm font-medium text-ink-80">Anything else?</label>
    <textarea
      id="message"
      name="message"
      rows="4"
      class="mt-1 w-full rounded-sm border border-[color:var(--color-divider)] bg-[color:var(--surface)] px-3 py-2 text-base"
    ></textarea>
  </div>

  {/* Honeypot — bots fill this; humans never see it. */}
  <div class="hidden" aria-hidden="true">
    <label>Leave this empty<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
  </div>

  <div class="sm:col-span-2">
    <button
      type="submit"
      disabled
      class="inline-flex min-h-touch cursor-not-allowed items-center rounded-md bg-ink-40 px-6 py-3 font-display font-semibold text-cream"
    >
      Request a proposal
    </button>
    <p id="proposal-status" class="mt-3 text-sm text-ink-60">
      Online submission is being connected. For now, email
      <a href={`mailto:${site.email}`} class="text-cedar underline">{site.email}</a>
      and Megan will reply within one business day.
    </p>
  </div>
</form>
