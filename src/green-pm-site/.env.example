# Copy to .env.local and fill in to enable backend integrations.
# The site builds and runs WITHOUT any of these (content falls back to sample
# data; forms fall back to a mailto link). Do NOT commit real values.

# --- Sanity (content layer) ------------------------------------------------
# When PROJECT_ID + DATASET are set, listings/blog/FAQs load from Sanity at build.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Only needed for draft/preview reads; public published content needs no token.
SANITY_API_TOKEN=

# --- Site --------------------------------------------------------------------
# Overrides the canonical production URL during preview/staging builds.
SITE_URL=https://greenpmpnw.com

# --- Forms (HubSpot) — used by the Cloudflare Pages Function (later) ---------
# PUBLIC_ values are exposed to the browser; secrets are runtime-only.
PUBLIC_FORMS_ENDPOINT=
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID_OWNER=
HUBSPOT_FORM_ID_RENTER=
HUBSPOT_API_TOKEN=
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Portal auth / PMS (later) ----------------------------------------------
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
RENTVINE_API_KEY=
DATABASE_URL=

# --- Analytics & observability ----------------------------------------------
# Cookieless web analytics (Plausible). When set, BaseLayout loads the script on
# indexable pages only; src/lib/analytics.ts sends custom events.
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_SENTRY_DSN=
