---
interface Props {
  /** Tailwind max-width utility; defaults to a comfortable reading width. */
  width?: 'prose' | 'lg' | 'xl';
  as?: string;
  class?: string;
}
const { width = 'xl', as = 'div', class: className = '' } = Astro.props as Props;
const max = width === 'prose' ? 'max-w-prose' : width === 'lg' ? 'max-w-[1024px]' : 'max-w-[1280px]';
const Tag = as as any;
---
<Tag class={`mx-auto w-full ${max} px-4 sm:px-6 lg:px-8 ${className}`}>
  <slot />
</Tag>
