---
/**
 * Disabled submit + explanatory note, used wherever a form's backend isn't
 * wired yet (proposal, inquiry, repair, rent). Keeps the "no silently dropped
 * action" pattern in one place. The note content is passed via the default slot.
 */
interface Props {
  label: string;
  statusId?: string;
}
const { label, statusId = 'submit-status' } = Astro.props;
---
<div class="sm:col-span-2">
  <button
    type="submit"
    disabled
    aria-describedby={statusId}
    class="inline-flex min-h-touch cursor-not-allowed items-center rounded-md bg-ink-40 px-6 py-3 font-display font-semibold text-cream"
  >
    {label}
  </button>
  <p id={statusId} class="mt-3 text-sm text-ink-60">
    <slot />
  </p>
</div>
