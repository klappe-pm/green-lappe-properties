---
import Container from '../../components/Container.astro';

const paths = [
  {
    eyebrow: 'For owners',
    title: 'Hand your rental to someone who picks up the phone',
    body: 'Leasing, screening, maintenance coordination, and owner statements — with pricing you can read on one line.',
    href: '/owners',
    cta: 'How we work with owners',
  },
  {
    eyebrow: 'For renters',
    title: 'Find a well-kept home with a responsive manager',
    body: 'Current listings across the Eastside and Seattle, with straightforward applications and fast repair response.',
    href: '/rentals',
    cta: 'See available rentals',
  },
];
---
<section class="py-16">
  <Container class="grid gap-8 md:grid-cols-2">
    {
      paths.map((p) => (
        <article class="flex flex-col rounded-lg border border-[color:var(--color-divider)] bg-[color:var(--surface-alt)] p-8 shadow-1">
          <p class="eyebrow">{p.eyebrow}</p>
          <h2 class="mt-3 text-xl">{p.title}</h2>
          <p class="prose mt-3 flex-1">{p.body}</p>
          <a href={p.href} class="mt-6 font-display font-semibold text-cedar underline underline-offset-2">
            {p.cta} →
          </a>
        </article>
      ))
    }
  </Container>
</section>
