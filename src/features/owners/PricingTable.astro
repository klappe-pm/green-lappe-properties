---
import { site } from '../../config/site';
const rows = [
  { label: 'Management fee', value: site.pricing.managementFee },
  { label: 'Leasing / placement fee', value: site.pricing.leasingFee },
  { label: 'Maintenance markup', value: site.pricing.maintenanceMarkup },
];
---
<div class="overflow-x-auto rounded-lg border border-[color:var(--color-divider)]">
  <table class="tabular w-full border-collapse text-left">
    <caption class="sr-only">Green PM owner pricing</caption>
    <tbody>
      {
        rows.map((r) => (
          <tr class="border-b border-[color:var(--color-divider)] last:border-0">
            <th scope="row" class="bg-[color:var(--surface-alt)] px-5 py-4 font-display font-medium text-ink-80">
              {r.label}
            </th>
            <td class="px-5 py-4 font-display font-semibold text-ink">{r.value}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
