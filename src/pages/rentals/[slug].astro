---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import InquiryForm from '../../features/renter-inquiry/InquiryForm.astro';
import { fetchListings } from '../../features/rentals/listings';
import { formatRent, formatSpecs } from '../../lib/format';

export const getStaticPaths = (async () => {
  const listings = await fetchListings();
  return listings.map((listing) => ({
    params: { slug: listing.slug },
    props: { listing },
  }));
}) satisfies GetStaticPaths;

const { listing } = Astro.props;
const statusLabel: Record<typeof listing.status, string> = {
  available: 'Available now',
  'coming-soon': 'Coming soon',
  pending: 'Application pending',
  leased: 'Leased',
};
---
<BaseLayout
  title={listing.address}
  audience="renter-acquisition"
  description={`${formatSpecs(listing.bedrooms, listing.bathrooms, listing.sqft)} in ${listing.neighborhood} — ${formatRent(listing.rent)}.`}
>
  <section class="py-12">
    <Container>
      <a href="/rentals" class="text-sm text-cedar underline underline-offset-2">← All rentals</a>
      <div class="mt-6 aspect-[16/9] w-full rounded-lg bg-cedar-gradient"></div>

      <div class="mt-8 grid gap-12 lg:grid-cols-[1.5fr_1fr]">
        <div>
          <p class="eyebrow">{listing.neighborhood} · {statusLabel[listing.status]}</p>
          <h1 class="mt-3">{listing.address}</h1>
          <p class="tabular mt-2 text-md text-ink-60">{formatSpecs(listing.bedrooms, listing.bathrooms, listing.sqft)}</p>
          <p class="tabular mt-4 font-display text-2xl font-semibold text-ink">{formatRent(listing.rent)}</p>

          <div class="prose mt-8">
            <p>{listing.description}</p>
          </div>

          <h2 class="text-lg">Amenities</h2>
          <ul class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2">
            {listing.amenities.map((a) => <li class="text-base text-ink-80">• {a}</li>)}
          </ul>

          <h2 class="text-lg">Pets</h2>
          <p class="prose mt-2">{listing.petPolicy}</p>
        </div>

        <aside class="lg:sticky lg:top-8 lg:self-start">
          <div class="rounded-lg border border-[color:var(--color-divider)] bg-[color:var(--surface-alt)] p-6">
            <h2 class="mt-0 text-lg">Inquire about this home</h2>
            <p class="prose mt-2 mb-6">Megan replies within one business day with showing details.</p>
            <InquiryForm listingAddress={listing.address} />
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>
