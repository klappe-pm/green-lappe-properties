---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import { site } from '../config/site';
---
<BaseLayout title="About" audience="neutral-acquisition" description={`About ${site.name} and ${site.broker.name}.`}>
  <section class="py-16">
    <Container width="prose">
      <p class="eyebrow">About</p>
      <h1 class="mt-4">A local manager, not a call center</h1>
      <div class="prose mt-6">
        <p>
          {site.name} is a boutique residential property manager serving
          {site.serviceArea}. We keep a small book on purpose: owners get a
          direct line, and residents get fast, respectful service.
        </p>
        <p>
          {site.broker.name} is the {site.broker.title.toLowerCase()} responsible
          for the brokerage and client trust obligations under Washington law.
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
