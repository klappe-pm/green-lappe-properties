---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import DraftNotice from '../features/legal/DraftNotice.astro';
---
<BaseLayout title="Privacy policy" audience="neutral-acquisition" description="How Green PM handles personal information.">
  <section class="py-16">
    <Container width="prose">
      <p class="eyebrow">Legal</p>
      <h1 class="mt-4 mb-6">Privacy policy</h1>
      <DraftNotice />
      <div class="prose mt-8">
        <p>
          Green Property Management collects only the information needed to
          respond to inquiries, screen applicants, and manage tenancies. Final
          policy language is pending counsel review.
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
