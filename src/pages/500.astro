---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { site } from '../config/site';
---
<BaseLayout title="Something went wrong" audience="neutral-acquisition">
  <section class="py-24">
    <Container width="prose">
      <p class="eyebrow">500</p>
      <h1 class="mt-4">Something went wrong on our end</h1>
      <p class="prose mt-6 mb-8">
        Please try again in a moment. If it keeps happening, email
        <a href={`mailto:${site.email}`}>{site.email}</a> and we’ll sort it out.
      </p>
      <Button href="/" variant="primary">Back home</Button>
    </Container>
  </section>
</BaseLayout>
